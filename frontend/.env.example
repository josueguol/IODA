# Copiar a .env y ajustar según tu entorno
# DEV/QA recomendado: backend en Docker Compose profile "services" (puertos 5001-5005)
# Para CORS: Backend/DevOps deben permitir el origen del frontend (ver docs/FASE_DE_SEGUIMIENTO/CORS_ORIGINS.md).

# Origen del frontend (opcional: si no se define, en el navegador se usa window.location.origin)
# Desarrollo: http://localhost:5173  (Vite por defecto)
# Staging/Prod: https://tu-dominio.com
# VITE_APP_ORIGIN=http://localhost:5173

VITE_CORE_API_URL=http://localhost:5001
VITE_IDENTITY_API_URL=http://localhost:5002
VITE_AUTHORIZATION_API_URL=http://localhost:5003
VITE_PUBLISHING_API_URL=http://localhost:5004
VITE_INDEXING_API_URL=http://localhost:5005
VITE_ENABLE_RICHTEXT_EDITOR=true
